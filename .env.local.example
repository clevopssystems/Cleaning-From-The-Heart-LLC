# ============================================================
# COPY THIS FILE TO .env.local — never commit .env.local
# ============================================================

# --- hCaptcha ---
# Site key (public — used in the browser widget)
# Get yours at: https://dashboard.hcaptcha.com/sites
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key_here

# Secret key (private — used only on the server to verify tokens)
# Get yours at: https://dashboard.hcaptcha.com/settings
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key_here

# --- Resend (email service) ---
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Upstash Redis (rate limiting — shared across all Vercel serverless instances) ---
# Free tier: https://console.upstash.com → create a Redis database → .env.local tab
# REQUIRED in production. Without these, rate limiting is disabled and a warning is logged.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# --- Contact destination ---
# The email address that receives form submissions
CONTACT_EMAIL=Cleanfromtheheartllc@gmail.com
